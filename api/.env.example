# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Encompass LOS Integration (optional - uses stub if not provided)
ENCOMPASS_CLIENT_ID=
ENCOMPASS_CLIENT_SECRET=
ENCOMPASS_INSTANCE_ID=

# DataTree API (First American) - for AVM and property data
DATATREE_APP_ID=
DATATREE_APP_KEY=
DATATREE_BASE_URL=https://api.firstam.io
DATATREE_TIMEOUT=30000

# PropertyReach API - for property data, STR detection, skip trace
PROPERTYREACH_API_KEY=
PROPERTYREACH_BASE_URL=https://api.propertyreach.com/v1
PROPERTYREACH_TIMEOUT=30000

# RentCast API - Primary AVM and rent estimates
RENTCAST_API_KEY=
RENTCAST_BASE_URL=https://api.rentcast.io/v1
RENTCAST_TIMEOUT=30

# Clear Capital Property Analytics API - Premium AVM verification
# Only called when DSCR > 0.75 AND LTV > 65% AND scrape verification passes
CLEAR_CAPITAL_API_KEY=
CLEAR_CAPITAL_BASE_URL=https://api.integ.clearcapital.com/property-analytics-api
CLEAR_CAPITAL_TIMEOUT=30

# Scraper rate limiting (milliseconds between requests)
ZILLOW_SCRAPE_DELAY_MS=2000
REDFIN_SCRAPE_DELAY_MS=2000

# Pipeline thresholds (optional - defaults shown)
# PREMIUM_DSCR_THRESHOLD=0.75
# PREMIUM_LTV_THRESHOLD=65.0

# Server
HOST=0.0.0.0
PORT=8000
